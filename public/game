<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Quest for The Glowing Stones</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #0d1b3d 0%, #1a2d5c 100%);
            font-family: 'Georgia', serif;
            overflow: hidden;
        }

        .container {
            position: relative;
            width: 800px;
            height: 600px;
            border: 4px solid #00ffff;
            box-shadow: 0 0 40px rgba(0,255,255,0.5), inset 0 0 40px rgba(0,255,255,0.1);
            border-radius: 12px;
            overflow: hidden;
        }

        canvas { display: block; width: 100%; height: 100%; }

        .hidden { display: none !important; }

        .screen {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
        }

        /* START SCREEN */
        #startScreen {
            background: linear-gradient(135deg, rgba(0,20,60,0.97), rgba(0,50,100,0.97));
            color: #00ffff;
            text-align: center;
            padding: 40px;
            gap: 20px;
            overflow-y: auto;
        }
        #startScreen h1 {
            font-size: 46px;
            text-shadow: 0 0 20px #00ffff, 0 0 40px #0099ff;
            letter-spacing: 2px;
            animation: glow-pulse 2s infinite;
            line-height: 1.2;
        }
        #startScreen h2 {
            font-size: 20px;
            color: #ffff99;
            text-shadow: 0 0 10px #ffff99;
        }
        #storyText {
            max-width: 580px;
            font-size: 15px;
            color: #00ffff;
            line-height: 1.8;
            background: rgba(0,150,200,0.2);
            padding: 18px 22px;
            border-radius: 10px;
            border: 1px solid rgba(0,255,255,0.4);
        }
        #controlsText {
            font-size: 13px;
            color: #ffff99;
            text-shadow: 0 0 5px #ffff99;
        }

        /* BUTTONS */
        button {
            padding: 14px 48px;
            font-size: 20px;
            background: linear-gradient(135deg, #00ffff, #00aaff);
            color: #000033;
            border: 2px solid #ffffff;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 0 20px rgba(0,255,255,0.4);
        }
        button:hover { transform: scale(1.1); box-shadow: 0 0 35px rgba(0,255,255,0.7); }
        button:active { transform: scale(0.96); }

        /* GAME OVER */
        #gameOverScreen {
            background: linear-gradient(135deg, rgba(50,0,20,0.97), rgba(100,0,50,0.97));
            color: #ff6b6b;
            gap: 24px;
        }
        #gameOverScreen h2 { font-size: 48px; text-shadow: 0 0 20px #ff6b6b; animation: glow-pulse 2s infinite; }
        #gameOverScreen p { font-size: 20px; color: #ffff99; }
        #finalScore { color: #ffff00; font-weight: bold; font-size: 30px; text-shadow: 0 0 10px #ffff00; }

        /* VICTORY */
        #victoryScreen {
            background: linear-gradient(135deg, rgba(0,60,20,0.97), rgba(0,100,50,0.97));
            color: #00ff99;
            gap: 24px;
        }
        #victoryScreen h2 { font-size: 48px; text-shadow: 0 0 20px #00ff99; animation: glow-pulse 2s infinite; }
        #victoryMessage { font-size: 22px; color: #ffff99; text-shadow: 0 0 10px #ffff99; line-height: 1.8; text-align: center; }
        #victoryScore { font-size: 26px; color: #ffff00; text-shadow: 0 0 10px #ffff00; }

        /* HUD */
        .hud {
            position: absolute;
            top: 10px;
            width: 100%;
            display: flex;
            justify-content: space-around;
            padding: 8px 20px;
            color: #00ffff;
            font-size: 16px;
            font-weight: bold;
            text-shadow: 0 0 10px #00ffff;
            z-index: 50;
            pointer-events: none;
        }
        .hud-item {
            background: rgba(0,51,102,0.85);
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid rgba(0,255,255,0.5);
        }

        /* LEVEL DISPLAY */
        #levelDisplay {
            position: absolute;
            bottom: 16px; right: 16px;
            background: rgba(0,51,102,0.85);
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,153,0.5);
            color: #ffff99;
            font-weight: bold;
            text-shadow: 0 0 10px #ffff99;
            z-index: 50;
            pointer-events: none;
        }

        /* LEVEL COMPLETE — moved to top-right side of screen */
        #levelCompleteMessage {
            position: absolute;
            top: 70px; right: 20px;
            background: rgba(0,0,0,0.88);
            color: #00ff99;
            padding: 14px 22px;
            border-radius: 12px;
            border: 2px solid #00ff99;
            text-align: center;
            z-index: 200;
            font-size: 18px;
            font-weight: bold;
            text-shadow: 0 0 12px #00ff99;
            box-shadow: 0 0 24px rgba(0,255,153,0.4);
            pointer-events: none;
            animation: levelPop 0.4s ease-out;
            max-width: 200px;
        }
        @keyframes levelPop {
            0%   { transform: translateX(120%); opacity: 0; }
            70%  { transform: translateX(-8%);  opacity: 1; }
            100% { transform: translateX(0);    opacity: 1; }
        }

        /* INVINCIBILITY FLASH */
        #invincibilityFlash {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(255,0,0,0.18);
            z-index: 150;
            pointer-events: none;
            animation: flash-out 0.4s forwards;
        }

        /* PLAYER LABELS */
        .player-label {
            position: absolute;
            font-weight: bold;
            font-size: 11px;
            color: #fff;
            text-shadow: 0 0 5px #000;
            z-index: 40;
            pointer-events: none;
        }
        #miaLabel  { color: #ff69b4; text-shadow: 0 0 5px #ff1493; }
        #jakeLabel { color: #00ff99; text-shadow: 0 0 5px #00cc77; }

        /* ANIMATIONS */
        @keyframes glow-pulse {
            0%, 100% { text-shadow: 0 0 10px currentColor; }
            50%       { text-shadow: 0 0 30px currentColor, 0 0 60px currentColor; }
        }
        @keyframes flash-out {
            0%   { opacity: 1; }
            100% { opacity: 0; }
        }
    
        /* ===== VIRTUAL D-PAD ===== */
        .dpad {
            position: absolute;
            bottom: 20px;
            left: 20px;
            z-index: 100;
            pointer-events: none;
        }
        .dpad-row {
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .dpad-btn {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(0, 180, 216, 0.35);
            border: 3px solid rgba(0, 255, 255, 0.7);
            color: white;
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            pointer-events: all;
            user-select: none;
            -webkit-user-select: none;
            touch-action: none;
            transition: background 0.1s;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 10px rgba(0,255,255,0.2);
            margin: 3px;
        }
        .dpad-btn:active, .dpad-btn.pressed {
            background: rgba(0, 255, 255, 0.45);
            border-color: rgba(0, 255, 255, 0.9);
            transform: scale(0.93);
        }
        .dpad-center {
            width: 65px;
            height: 65px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,0.3);
            font-size: 20px;
            margin: 3px;
        }
    </style>
</head>
<body>
<div class="container" id="gameContainer">
    <canvas id="gameCanvas" width="800" height="600"></canvas>

    <div class="hud hidden" id="hud">
        <div class="hud-item">⭐ Score: <span id="scoreDisplay">0</span></div>
        <div class="hud-item">❤️ Lives: <span id="livesDisplay">3</span></div>
        <div class="hud-item">💎 Stones: <span id="stonesDisplay">0</span>/15</div>
    </div>

    <div id="levelDisplay" class="hidden">🏆 Level <span id="levelNum">1</span></div>
    <div id="levelCompleteMessage" class="hidden">✨ Level Complete! ✨</div>

    <!-- START SCREEN -->
    <div class="screen" id="startScreen">
        <h1>✨ THE QUEST FOR THE GLOWING STONES ✨</h1>
        <h2>Mia &amp; Jake's Treasure Mission</h2>
        <div id="storyText">
            <p>🧜‍♀️ <strong>Mia</strong> and 🧜 <strong>Jake</strong> are on an underwater treasure mission!</p>
            <p style="margin-top:10px;">They must collect <strong>glowing stones</strong> hidden beneath the sea while avoiding jellyfish, sea urchins, and rocks.</p>
            <p style="margin-top:10px;"><strong>⚡ Collect 15 stones to win! ⚡</strong></p>
        </div>
        <div id="controlsText">
            ⬅️ Arrow Keys / WASD to Move ➡️ &nbsp;|&nbsp; M = Switch to Mia &nbsp;|&nbsp; J = Switch to Jake
        </div>
        <button id="startButton">🎮 START ADVENTURE 🎮</button>
    </div>

    <!-- VICTORY SCREEN -->
    <div class="screen hidden" id="victoryScreen">
        <h2>🎉 YOU WON! 🎉</h2>
        <div id="victoryMessage">
            <p>✨ Mia and Jake found all the glowing stones! ✨</p>
            <p style="margin-top:12px;">They became legendary underwater treasure hunters!</p>
        </div>
        <div id="victoryScore">🌟 Final Score: <span id="victoryScoreValue">0</span> 🌟</div>
        <button id="victoryRestartButton">🎮 PLAY AGAIN 🎮</button>
    </div>

    <!-- GAME OVER SCREEN -->
    <div class="screen hidden" id="gameOverScreen">
        <h2>Game Over!</h2>
        <p>Your Final Score: <span id="finalScore">0</span></p>
        <p>Stones Collected: <span id="finalStones">0</span>/15</p>
        <button id="restartButton">🎮 TRY AGAIN 🎮</button>
    </div>

    <div class="player-label hidden" id="miaLabel">✦ Mia</div>
    <div class="player-label hidden" id="jakeLabel">✦ Jake</div>

    <!-- VIRTUAL D-PAD for phones and tablets -->
    <div id="dpad" style="display:none;position:absolute;bottom:25px;left:25px;z-index:100;">
        <!-- UP button row -->
        <div style="display:flex;justify-content:center;margin-bottom:3px;">
            <div id="btn-up" class="dpad-btn"
                ontouchstart="event.preventDefault();dpadPress('ArrowUp')"
                ontouchend="event.preventDefault();dpadRelease('ArrowUp')"
                onmousedown="dpadPress('ArrowUp')"
                onmouseup="dpadRelease('ArrowUp')">▲</div>
        </div>
        <!-- LEFT CENTER RIGHT row -->
        <div style="display:flex;align-items:center;gap:3px;">
            <div id="btn-left" class="dpad-btn"
                ontouchstart="event.preventDefault();dpadPress('ArrowLeft')"
                ontouchend="event.preventDefault();dpadRelease('ArrowLeft')"
                onmousedown="dpadPress('ArrowLeft')"
                onmouseup="dpadRelease('ArrowLeft')">◀</div>
            <div style="width:65px;height:65px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.3);font-size:22px;">✦</div>
            <div id="btn-right" class="dpad-btn"
                ontouchstart="event.preventDefault();dpadPress('ArrowRight')"
                ontouchend="event.preventDefault();dpadRelease('ArrowRight')"
                onmousedown="dpadPress('ArrowRight')"
                onmouseup="dpadRelease('ArrowRight')">▶</div>
        </div>
        <!-- DOWN button row -->
        <div style="display:flex;justify-content:center;margin-top:3px;">
            <div id="btn-down" class="dpad-btn"
                ontouchstart="event.preventDefault();dpadPress('ArrowDown')"
                ontouchend="event.preventDefault();dpadRelease('ArrowDown')"
                onmousedown="dpadPress('ArrowDown')"
                onmouseup="dpadRelease('ArrowDown')">▼</div>
        </div>
    </div>

</div>

<script>

// ===== AUTO SCREEN FITTING =====
function autoFitGame() {
    const container = document.querySelector('.container');
    if (!container) return;
    const gameW = 800;
    const gameH = 600;
    const screenW = window.innerWidth;
    const screenH = window.innerHeight;
    const scaleX = screenW / gameW;
    const scaleY = screenH / gameH;
    const scale = Math.min(scaleX, scaleY, 1);
    container.style.transform = 'scale(' + scale + ')';
    container.style.transformOrigin = 'top center';
    const scaledH = gameH * scale;
    const topOffset = Math.max(0, (screenH - scaledH) / 2);
    container.style.marginTop = topOffset + 'px';
    const dpad = document.getElementById('dpad');
    if (dpad) {
        if (scale < 0.7) {
            dpad.style.bottom = '15px';
            dpad.style.left = '15px';
        } else {
            dpad.style.bottom = '25px';
            dpad.style.left = '25px';
        }
    }
}
window.addEventListener('resize', autoFitGame);
window.addEventListener('orientationchange', function() { setTimeout(autoFitGame, 300); });
document.addEventListener('DOMContentLoaded', autoFitGame);

// ===== FORCE SHOW DPAD ON TOUCH DEVICES =====
(function() {
    if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
        document.addEventListener('DOMContentLoaded', function() {
            var dpad = document.getElementById('dpad');
            // Override: show dpad as soon as start button is clicked
            var startBtn = document.getElementById('startButton');
            if (startBtn) {
                startBtn.addEventListener('touchstart', function() {
                    setTimeout(function() {
                        var d = document.getElementById('dpad');
                        if (d) d.style.display = 'block';
                    }, 100);
                });
            }
        });
    }
})();

// ===== AUTO DETECT TOUCH DEVICE =====
function isTouchDevice() {
    return (('ontouchstart' in window) || (navigator.maxTouchPoints > 0));
}
// Show dpad automatically on phones/tablets
if (isTouchDevice()) {
    document.addEventListener('DOMContentLoaded', () => {
        // Will show when game starts via showDpad()
    });
}

// ===== VIRTUAL D-PAD CONTROLS =====
function dpadPress(key) {
    keys[key.toLowerCase()] = true;
    // Visual feedback
    const btnMap = {
        'ArrowUp': 'btn-up',
        'ArrowDown': 'btn-down',
        'ArrowLeft': 'btn-left',
        'ArrowRight': 'btn-right'
    };
    const btn = document.getElementById(btnMap[key]);
    if (btn) btn.classList.add('pressed');
}

function dpadRelease(key) {
    keys[key.toLowerCase()] = false;
    const btnMap = {
        'ArrowUp': 'btn-up',
        'ArrowDown': 'btn-down',
        'ArrowLeft': 'btn-left',
        'ArrowRight': 'btn-right'
    };
    const btn = document.getElementById(btnMap[key]);
    if (btn) btn.classList.remove('pressed');
}

// Show/hide dpad based on game state
function showDpad() { document.getElementById('dpad').style.display = 'block'; }
function hideDpad() { document.getElementById('dpad').style.display = 'none'; }

// Always show dpad on touch devices
if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    document.addEventListener('DOMContentLoaded', function() {
        // Dpad shows when game starts via startGameFunc
    });
}

// ===== BACKGROUND IMAGE =====
const bgImage = new Image();
bgImage.src = 'background.png';

// ===== CONSTANTS =====
const STONES_TO_WIN     = 15;
const MAX_STONES        = 10;
const INVINCIBLE_FRAMES = 90;   // ~1.5 seconds at 60fps
const MIN_SPAWN_INTERVAL = 20;  // prevent modulo-zero crash

// ===== CANVAS =====
const canvas = document.getElementById('gameCanvas');
const ctx    = canvas.getContext('2d');

// ===== UI REFS =====
const startScreen          = document.getElementById('startScreen');
const gameOverScreen       = document.getElementById('gameOverScreen');
const victoryScreen        = document.getElementById('victoryScreen');
const hud                  = document.getElementById('hud');
const levelDisplay         = document.getElementById('levelDisplay');
const levelCompleteMessage = document.getElementById('levelCompleteMessage');
const scoreDisplay         = document.getElementById('scoreDisplay');
const livesDisplay         = document.getElementById('livesDisplay');
const stonesDisplay        = document.getElementById('stonesDisplay');
const levelNum             = document.getElementById('levelNum');
const finalScore           = document.getElementById('finalScore');
const finalStones          = document.getElementById('finalStones');
const victoryScoreValue    = document.getElementById('victoryScoreValue');
const miaLabel             = document.getElementById('miaLabel');
const jakeLabel            = document.getElementById('jakeLabel');
const gameContainer        = document.getElementById('gameContainer');

// ===== GAME STATE =====
let gameState        = 'start';
let score            = 0;
let lives            = 3;
let stonesCollected  = 0;
let currentLevel     = 1;
let gameFrame        = 0;
let gameSpeed        = 1;
let rafId            = null;
let levelCompleteShown = false;
let invincibleFrames = 0;  // FIX #3: invincibility frames after hit

// ===== AUDIO (lazy init — FIX #5) =====
let audioCtx = null;
function getAudioCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
}
function playTone(freq, duration, type = 'sine', vol = 0.25) {
    try {
        const ctx2 = getAudioCtx();
        const osc  = ctx2.createOscillator();
        const gain = ctx2.createGain();
        osc.connect(gain);
        gain.connect(ctx2.destination);
        osc.frequency.value = freq;
        osc.type = type;
        gain.gain.setValueAtTime(vol, ctx2.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx2.currentTime + duration);
        osc.start(ctx2.currentTime);
        osc.stop(ctx2.currentTime + duration);
    } catch(e) {}
}
const playCollectSound     = () => { playTone(800,0.12); setTimeout(()=>playTone(1000,0.12),70); setTimeout(()=>playTone(1200,0.15),140); };
const playHitSound         = () => { playTone(200,0.3,'square',0.2); };
const playGameOverSound    = () => { playTone(400,0.3); setTimeout(()=>playTone(280,0.3),160); setTimeout(()=>playTone(180,0.5),320); };
const playVictorySound     = () => { playTone(800,0.2); setTimeout(()=>playTone(1000,0.2),160); setTimeout(()=>playTone(1300,0.4),320); };
const playLevelUpSound     = () => { playTone(600,0.18); setTimeout(()=>playTone(800,0.18),150); setTimeout(()=>playTone(1000,0.25),300); };

// ===== INPUT =====
// FIX #8: normalise key to lowercase so Caps Lock doesn't break M/J switch
const keys = {};
window.addEventListener('keydown', e => { keys[e.key.toLowerCase()] = true; e.preventDefault && ['arrowup','arrowdown','arrowleft','arrowright',' '].includes(e.key.toLowerCase()) && e.preventDefault(); });
window.addEventListener('keyup',   e => { keys[e.key.toLowerCase()] = false; });

// ===== CHARACTER IMAGES (Pixar-style 3D renders of Mia & Jake) =====
const miaImg = new Image();
const jakeImg = new Image();
let charactersReady = { mia: false, jake: false };
miaImg.onload = () => { charactersReady.mia = true; };
jakeImg.onload = () => { charactersReady.jake = true; };
miaImg.src  = "data:image/png;base64,";
jakeImg.src = "data:image/png;base64,";

// ===== PLAYER =====
const player = {
    x: 400, y: 500,
    width: 60, height: 50,
    speed: 5,
    isMia: true,
    switchCooldown: 0,

    reset() { this.x = 400; this.y = 500; this.isMia = true; },

    update() {
        const spd = this.speed;
        // Arrow keys AND WASD
        if ((keys['arrowleft']  || keys['a']) && this.x > 10)                           this.x -= spd;
        if ((keys['arrowright'] || keys['d']) && this.x < canvas.width - this.width - 10) this.x += spd;
        if ((keys['arrowup']    || keys['w']) && this.y > 50)                            this.y -= spd;
        if ((keys['arrowdown']  || keys['s']) && this.y < canvas.height - this.height - 10) this.y += spd;

        // Character switch (FIX #8 — keys already lowercase)
        if (this.switchCooldown === 0) {
            if (keys['m']) { this.isMia = true;  this.switchCooldown = 20; }
            if (keys['j']) { this.isMia = false; this.switchCooldown = 20; }
        }
        if (this.switchCooldown > 0) this.switchCooldown--;

        // Labels
        const lx = this.x - 10, ly = this.y - 28;
        miaLabel.style.left  = lx + 'px';
        miaLabel.style.top   = ly + 'px';
        jakeLabel.style.left = lx + 'px';
        jakeLabel.style.top  = ly + 'px';
        miaLabel.classList.toggle('hidden', !this.isMia);
        jakeLabel.classList.toggle('hidden', this.isMia);
    },

    // Track facing direction for sprite flip (face the way you're moving)
    facingLeft: false,
    lastX: 400,

    draw() {
        // Flash when invincible
        if (invincibleFrames > 0 && Math.floor(invincibleFrames / 6) % 2 === 0) return;

        // Update facing direction based on horizontal movement
        if (this.x < this.lastX - 0.5) this.facingLeft = true;
        else if (this.x > this.lastX + 0.5) this.facingLeft = false;
        this.lastX = this.x;

        const img = this.isMia ? miaImg : jakeImg;
        const ready = this.isMia ? charactersReady.mia : charactersReady.jake;

        // Fallback to simple drawing if images haven't loaded yet
        if (!ready) { this.drawFallback(); return; }

        // ===== SWIMMING ANIMATION =====
        // Gentle vertical bob (like bobbing in water)
        const bob = Math.sin(gameFrame * 0.12) * 3;
        // Subtle tilt rotation (swimming wiggle)
        const tilt = Math.sin(gameFrame * 0.18) * 0.08;
        // Bubble trail behind swimmer
        if (gameFrame % 12 === 0) {
            spawnBubbles(this.x + (this.facingLeft ? this.width : 0), this.y + this.height/2, 1);
        }

        // Glow aura — different color per character
        ctx.save();
        const glowColor = this.isMia ? 'rgba(255,180,200,0.55)' : 'rgba(120,200,255,0.55)';
        ctx.shadowColor = glowColor;
        ctx.shadowBlur  = 22;

        // Translate to character center for rotation/flip
        const cx = this.x + this.width/2;
        const cy = this.y + this.height/2 + bob;
        ctx.translate(cx, cy);
        ctx.rotate(tilt);
        if (this.facingLeft) ctx.scale(-1, 1);

        // Draw image centered. Maintain aspect ratio of the source.
        const aspect = img.width / img.height; // ~1.5 (200x133)
        const drawH  = this.height + 20;       // ~70 — render larger than hitbox so character looks present
        const drawW  = drawH * aspect;
        ctx.drawImage(img, -drawW/2, -drawH/2, drawW, drawH);

        ctx.restore();
        ctx.shadowColor = 'transparent';
    },

    drawFallback() {
        // Tiny placeholder while PNGs load
        const {x, y} = this;
        ctx.fillStyle = this.isMia ? '#ff6b6b' : '#4a90e2';
        ctx.beginPath();
        ctx.arc(x + this.width/2, y + this.height/2, 14, 0, Math.PI*2);
        ctx.fill();
    }
};

// ===== AABB COLLISION =====
function collides(a, b) {
    return a.x < b.x + b.width  &&
           a.x + a.width  > b.x &&
           a.y < b.y + b.height &&
           a.y + a.height > b.y;
}

// ===== STONES =====
let stones = [];
class Stone {
    constructor() {
        this.x      = Math.random() * (canvas.width - 60) + 20;
        this.y      = Math.random() * (canvas.height - 160) + 80;
        this.width  = 14;
        this.height = 14;
        this.rotation   = 0;
        this.floatSpeed = Math.random() * 0.03 + 0.02;
        this.floatOffset = Math.random() * Math.PI * 2;
    }
    update() {
        this.rotation += 0.05;
    }
    draw() {
        const glow = Math.sin(gameFrame * 0.05) * 0.5 + 0.5;
        const floatY = Math.sin(gameFrame * this.floatSpeed + this.floatOffset) * 3;
        ctx.save();
        ctx.translate(this.x + 7, this.y + 7 + floatY);
        ctx.rotate(this.rotation);
        ctx.shadowColor = `rgba(255,255,0,${0.4 + glow * 0.6})`;
        ctx.shadowBlur  = 18;
        ctx.fillStyle   = '#ffff00';
        ctx.beginPath();
        ctx.moveTo(0,-7); ctx.lineTo(7,-3.5); ctx.lineTo(7,3.5);
        ctx.lineTo(0,7); ctx.lineTo(-7,3.5); ctx.lineTo(-7,-3.5);
        ctx.closePath(); ctx.fill();
        ctx.fillStyle = '#ffffff'; ctx.shadowColor = 'transparent';
        ctx.fillRect(-1,-1,3,3);
        ctx.strokeStyle = '#ffff99'; ctx.lineWidth = 1; ctx.stroke();
        ctx.restore();
    }
}

// ===== OBSTACLES =====
let obstacles = [];
class Obstacle {
    constructor(type) {
        this.type    = type || ['jellyfish','urchin','rock'][Math.floor(Math.random()*3)];
        this.x       = Math.random() * (canvas.width - 60) + 20;
        this.y       = -40;
        this.width   = 30;
        this.height  = 30;
        this.velY    = Math.random() * 0.6 + 0.4 + gameSpeed * 0.3;
        this.velX    = (Math.random() - 0.5) * (1.5 + gameSpeed * 0.4);
        this.wobble  = Math.random() * Math.PI * 2;
        this.wobbleSpeed = Math.random() * 0.05 + 0.03;
    }
    update() {
        this.y += this.velY;
        this.x += this.velX;
        this.wobble += this.wobbleSpeed;
        if (this.x < 0 || this.x > canvas.width - this.width) this.velX *= -1;
        if (this.y > canvas.height + 20) {
            this.y = -40;
            this.x = Math.random() * (canvas.width - this.width);
        }
    }
    draw() {
        if      (this.type === 'jellyfish') this.drawJellyfish();
        else if (this.type === 'urchin')    this.drawUrchin();
        else                                this.drawRock();
    }
    drawJellyfish() {
        const {x,y,wobble} = this;
        ctx.shadowColor = 'rgba(255,150,200,0.4)'; ctx.shadowBlur = 12;
        ctx.fillStyle = '#ff99cc'; ctx.globalAlpha = 0.85;
        ctx.beginPath(); ctx.ellipse(x+15,y+8,13,11,0,0,Math.PI*2); ctx.fill();
        ctx.globalAlpha = 1;
        ctx.fillStyle = '#ff00ff';
        ctx.fillRect(x+11,y+5,2.5,2.5); ctx.fillRect(x+18.5,y+5,2.5,2.5);
        ctx.strokeStyle='#ff99cc'; ctx.lineWidth=2;
        for (let i=0;i<5;i++) {
            const bx = x+6+i*4.5;
            ctx.beginPath(); ctx.moveTo(bx, y+19);
            ctx.quadraticCurveTo(bx + Math.sin(wobble+i)*6, y+26, bx, y+33);
            ctx.stroke();
        }
        ctx.shadowColor='transparent';
    }
    drawUrchin() {
        const {x,y} = this;
        ctx.shadowColor='rgba(255,100,100,0.4)'; ctx.shadowBlur=12;
        ctx.fillStyle='#ff6b6b';
        ctx.beginPath(); ctx.arc(x+15,y+15,11,0,Math.PI*2); ctx.fill();
        ctx.strokeStyle='#ff3333'; ctx.lineWidth=2.5;
        for (let i=0;i<10;i++) {
            const a = (i/10)*Math.PI*2;
            ctx.beginPath();
            ctx.moveTo(x+15+Math.cos(a)*11, y+15+Math.sin(a)*11);
            ctx.lineTo(x+15+Math.cos(a)*21, y+15+Math.sin(a)*21);
            ctx.stroke();
        }
        ctx.fillStyle='#000';
        ctx.fillRect(x+12,y+12,2,2); ctx.fillRect(x+19,y+12,2,2);
        ctx.shadowColor='transparent';
    }
    drawRock() {
        const {x,y}=this;
        ctx.shadowColor='rgba(150,150,150,0.3)'; ctx.shadowBlur=8;
        ctx.fillStyle='#888';
        ctx.beginPath();
        ctx.moveTo(x+8,y+5); ctx.lineTo(x+24,y+6); ctx.lineTo(x+28,y+18);
        ctx.lineTo(x+22,y+30); ctx.lineTo(x+8,y+28); ctx.lineTo(x+2,y+18);
        ctx.closePath(); ctx.fill();
        ctx.fillStyle='#666'; ctx.fillRect(x+8,y+18,10,10);
        ctx.fillStyle='#aaa'; ctx.fillRect(x+10,y+8,8,5);
        ctx.shadowColor='transparent';
    }
}

// ===== BACKGROUND =====
let seaPlants = [], corals = [], backgroundFish = [];

class SeaPlant {
    constructor(x) {
        this.x = x; this.baseY = canvas.height - 20;
        this.height = Math.random()*40+50;
        this.waveSpeed = Math.random()*0.02+0.01;
        this.phaseOffset = Math.random()*Math.PI*2;
        this.color = ['#00cc99','#00ff99','#33dd99','#00dd88'][Math.floor(Math.random()*4)];
    }
    draw() {
        ctx.strokeStyle = this.color; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.moveTo(this.x, this.baseY);
        for (let i=0; i<this.height; i+=5) {
            ctx.lineTo(this.x + Math.sin(i*0.1 + gameFrame*this.waveSpeed + this.phaseOffset)*4, this.baseY - i);
        }
        ctx.stroke();
    }
}

class Coral {
    constructor(x, y) {
        this.x=x; this.y=y;
        this.color=['#ff6b9d','#ff9933','#ffcc00','#ff6666'][Math.floor(Math.random()*4)];
        this.size=Math.random()*15+10;
    }
    draw() {
        ctx.fillStyle = this.color;
        for (let i=0;i<4;i++) {
            const a=(i/4)*Math.PI*2;
            ctx.beginPath(); ctx.arc(this.x+Math.cos(a)*this.size, this.y+Math.sin(a)*this.size, this.size*0.4, 0, Math.PI*2); ctx.fill();
        }
        ctx.beginPath(); ctx.arc(this.x,this.y,this.size*0.5,0,Math.PI*2); ctx.fill();
    }
}

class BgFish {
    constructor() {
        this.x = Math.random()*canvas.width;
        this.y = Math.random()*(canvas.height-100)+50;
        this.speed = Math.random()*1.5+0.5;
        this.dir = Math.random()>0.5?1:-1;
        this.color1 = ['#ff9900','#ff6b6b','#00ff99','#ffff00','#ff66ff'][Math.floor(Math.random()*5)];
        this.color2 = ['#ffcc00','#ff99cc','#00ffcc','#ffff99','#ff99ff'][Math.floor(Math.random()*5)];
        this.size = Math.random()*8+6;
    }
    update() {
        this.x += this.speed * this.dir;
        if (this.x < -30 || this.x > canvas.width+30) {
            this.x = this.dir < 0 ? canvas.width+30 : -30;
            this.y = Math.random()*(canvas.height-100)+50;
        }
    }
    draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.scale(this.dir, 1);
        ctx.fillStyle = this.color1;
        ctx.beginPath(); ctx.ellipse(0,0,this.size,this.size*0.6,0,0,Math.PI*2); ctx.fill();
        ctx.fillStyle = this.color2;
        ctx.beginPath(); ctx.moveTo(-this.size,0); ctx.lineTo(-this.size-5,-5); ctx.lineTo(-this.size-5,5); ctx.closePath(); ctx.fill();
        ctx.restore();
    }
}

// Bubbles
let bubbles = [];
class Bubble {
    constructor(x,y) {
        this.x=x+(Math.random()-0.5)*20; this.y=y+(Math.random()-0.5)*20;
        this.r=Math.random()*3+1;
        this.vy=Math.random()*-0.9-0.3;
        this.vx=(Math.random()-0.5)*0.8;
        this.alpha=0.7;
    }
    update() { this.y+=this.vy; this.x+=this.vx; this.alpha-=0.012; }
    draw() {
        ctx.fillStyle=`rgba(100,200,255,${this.alpha*0.5})`;
        ctx.beginPath(); ctx.arc(this.x,this.y,this.r,0,Math.PI*2); ctx.fill();
        ctx.strokeStyle=`rgba(180,230,255,${this.alpha})`; ctx.lineWidth=0.8; ctx.stroke();
    }
    get alive() { return this.alpha>0; }
}

function spawnBubbles(x,y,n=8) {
    for (let i=0;i<n;i++) bubbles.push(new Bubble(x,y));
}

function drawLightRays() {
    ctx.save();
    ctx.strokeStyle='rgba(255,255,255,0.07)'; ctx.lineWidth=30;
    for (let i=0;i<4;i++) {
        ctx.beginPath(); ctx.moveTo(i*200+50,0); ctx.lineTo(i*200+130,canvas.height); ctx.stroke();
    }
    ctx.restore();
}

function initBackground() {
    seaPlants      = Array.from({length:6}, () => new SeaPlant(Math.random()*canvas.width));
    corals         = Array.from({length:8}, () => new Coral(Math.random()*canvas.width, canvas.height-40-Math.random()*55));
    backgroundFish = Array.from({length:7}, () => new BgFish());
}

// ===== SPAWN =====
function spawnStone() {
    if (stones.length < MAX_STONES) stones.push(new Stone());
}
function spawnObstacle() {
    const cap = 3 + currentLevel;
    if (obstacles.length < cap) obstacles.push(new Obstacle());
}

// ===== HUD =====
function updateHUD() {
    scoreDisplay.textContent  = score;
    livesDisplay.textContent  = lives;
    stonesDisplay.textContent = stonesCollected;
    levelNum.textContent      = currentLevel;
}

// ===== LEVEL PROGRESSION =====
// FIX #7: track exact threshold per level, not modulo
let nextLevelThreshold = 5;
function checkLevelProgression() {
    if (!levelCompleteShown && stonesCollected >= nextLevelThreshold && stonesCollected < STONES_TO_WIN) {
        levelCompleteShown = true;
        showLevelComplete();
    }
}
function showLevelComplete() {
    levelCompleteMessage.classList.remove('hidden');
    playLevelUpSound();
    setTimeout(() => {
        currentLevel++;
        // FIX #7: advance threshold by increasing amount each level
        nextLevelThreshold += 3 + currentLevel;
        levelCompleteMessage.classList.add('hidden');
        levelCompleteShown = false;
        gameSpeed = Math.min(gameSpeed + 0.15, 3);
        for (let i=0;i<2;i++) spawnObstacle();
        updateHUD();
    }, 2500);
}

// ===== GAME INIT =====
function initGame() {
    score = 0; lives = 3; stonesCollected = 0;
    currentLevel = 1; gameFrame = 0; gameSpeed = 1;
    invincibleFrames = 0; levelCompleteShown = false;
    nextLevelThreshold = 5;
    stones = []; obstacles = []; bubbles = [];
    player.reset();
    initBackground();
    for (let i=0;i<8;i++) spawnStone();
    for (let i=0;i<3;i++) spawnObstacle();
    updateHUD();
    hud.classList.remove('hidden');
    levelDisplay.classList.remove('hidden');
    miaLabel.classList.remove('hidden');
}

// ===== END GAME =====
function showFlash() {
    const old = document.getElementById('invincibilityFlash');
    if (old) old.remove();
    const el = document.createElement('div');
    el.id = 'invincibilityFlash';
    gameContainer.appendChild(el);
    setTimeout(() => el.remove(), 500);
}

function endGame() {
    hideDpad();
    gameState = 'gameOver';
    cancelAnimationFrame(rafId);
    hud.classList.add('hidden');
    levelDisplay.classList.add('hidden');
    miaLabel.classList.add('hidden');
    jakeLabel.classList.add('hidden');
    finalScore.textContent  = score;
    finalStones.textContent = stonesCollected;
    gameOverScreen.classList.remove('hidden');
    playGameOverSound();
}

function endGameVictory() {
    hideDpad();
    gameState = 'victory';
    cancelAnimationFrame(rafId);
    hud.classList.add('hidden');
    levelDisplay.classList.add('hidden');
    miaLabel.classList.add('hidden');
    jakeLabel.classList.add('hidden');
    victoryScoreValue.textContent = score;
    victoryScreen.classList.remove('hidden');
    playVictorySound();
}

function restartGame() {
    gameOverScreen.classList.add('hidden');
    victoryScreen.classList.add('hidden');
    startScreen.classList.remove('hidden');
    gameState = 'start';
}

// ===== MAIN LOOP (requestAnimationFrame — FIX #12) =====
function gameLoop() {
    if (gameState !== 'playing') return;
    rafId = requestAnimationFrame(gameLoop);
    gameFrame++;

    // Background
    const grad = ctx.createLinearGradient(0,0,0,canvas.height);
    grad.addColorStop(0,'#00ddff'); grad.addColorStop(0.3,'#00aabb');
    grad.addColorStop(0.6,'#008899'); grad.addColorStop(1,'#003366');
    ctx.fillStyle = grad; ctx.fillRect(0,0,canvas.width,canvas.height);
    drawLightRays();
    seaPlants.forEach(p => p.draw());
    corals.forEach(c => c.draw());
    backgroundFish.forEach(f => { f.update(); f.draw(); });

    // Bubbles
    bubbles = bubbles.filter(b => { b.update(); b.draw(); return b.alive; });

    // Player
    player.update();
    player.draw();
    if (invincibleFrames > 0) invincibleFrames--;

    // ---- STONES: FIX #1 collect into removal list, splice after loop ----
    const stonesToRemove = [];
    let won = false;
    for (const stone of stones) {
        stone.update();
        stone.draw();
        if (collides(stone, player)) {
            stonesToRemove.push(stone);
            score += 10;
            stonesCollected++;
            playCollectSound();
            spawnBubbles(stone.x, stone.y, 12);
            if (stonesCollected >= STONES_TO_WIN) { won = true; break; }
            checkLevelProgression();
        }
    }
    // Remove collected stones
    for (const s of stonesToRemove) stones.splice(stones.indexOf(s), 1);
    // Replenish
    for (let i = stonesToRemove.length; i > 0; i--) spawnStone();

    // FIX #2: check win AFTER loop, not inside forEach callback
    if (won) { endGameVictory(); return; }

    // ---- OBSTACLES: FIX #3 invincibility frames ----
    for (const obs of obstacles) {
        obs.update();
        obs.draw();
        if (invincibleFrames === 0 && collides(obs, player)) {
            lives--;
            playHitSound();
            spawnBubbles(player.x+15, player.y+20, 15);
            showFlash();
            invincibleFrames = INVINCIBLE_FRAMES;  // ~1.5 sec grace period
            player.x = 400; player.y = 500;
            updateHUD();
            if (lives <= 0) { endGame(); return; }
        }
    }

    // FIX #4: clamp spawn interval to avoid modulo-zero crash
    const spawnInterval = Math.max(MIN_SPAWN_INTERVAL, 100 - currentLevel * 10);
    if (gameFrame % spawnInterval === 0) spawnObstacle();

    updateHUD();
}

// ===== START GAME =====
function startGameFunc() {
    showDpad();
    gameState = 'playing';
    startScreen.classList.add('hidden');
    initGame();
    rafId = requestAnimationFrame(gameLoop);
}

// ===== EVENTS =====
document.getElementById('startButton').addEventListener('click', startGameFunc);
document.getElementById('restartButton').addEventListener('click', restartGame);
document.getElementById('victoryRestartButton').addEventListener('click', restartGame);
</script>
